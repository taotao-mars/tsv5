import io
import re
import boto3
import pandas as pd


BUCKET = "amxl-asin-forecast590184089576"

FEATURE_PREFIX = (
    "amxl-asin-forecast-intern/data_for_model/"
    "df_head_body_add_holiday_"
)

SCOT_PREFIX = "amxl-asin-forecast-intern/scotforecast/"

s3 = boto3.client("s3")


def list_keys(prefix):
    keys = []
    paginator = s3.get_paginator("list_objects_v2")

    for page in paginator.paginate(Bucket=BUCKET, Prefix=prefix):
        for obj in page.get("Contents", []):
            keys.append(obj["Key"])

    return keys


# 1. 找到所有 feature cut
feature_keys = list_keys(FEATURE_PREFIX)
scot_keys = list_keys(SCOT_PREFIX)

feature_by_date = {}
for key in feature_keys:
    match = re.search(
        r"df_head_body_add_holiday_(\d{4}-\d{2}-\d{2})_?ETLM_[vV]3\.csv$",
        key,
    )
    if match:
        cut_date = pd.Timestamp(match.group(1))
        feature_by_date[cut_date] = key


# 2. 找到所有 SCOT 文件
scot_by_date = {}
for key in scot_keys:
    match = re.search(
        r"from(\d{4}-\d{2}-\d{2})_20weeks__headbody_scot_fcst_"
        r"(?:no_refresh|refresh)\.parquet$",
        key,
    )

    if match:
        scot_date = pd.Timestamp(match.group(1))

        # 同一天优先 no_refresh
        if (
            scot_date not in scot_by_date
            or "no_refresh" in key
        ):
            scot_by_date[scot_date] = key


# 3. 每个 cut 读取 ASIN，并计算 inner join unique ASIN
results = []

for cut_date, feature_key in sorted(feature_by_date.items()):

    # feature cut 的下一天对应 SCOT FCD
    scot_date = cut_date + pd.Timedelta(days=1)
    scot_key = scot_by_date.get(scot_date)

    if scot_key is None:
        print(f"{cut_date.date()} | SCOT file not found")
        continue

    print(f"Processing cut {cut_date.date()}...", flush=True)

    # 只读取 asin 列
    feature_obj = s3.get_object(
        Bucket=BUCKET,
        Key=feature_key,
    )

    feature_df = pd.read_csv(
        feature_obj["Body"],
        usecols=["asin"],
    )

    scot_obj = s3.get_object(
        Bucket=BUCKET,
        Key=scot_key,
    )

    scot_bytes = scot_obj["Body"].read()

    scot_df = pd.read_parquet(
        io.BytesIO(scot_bytes),
        columns=["asin"],
    )

    # 统一类型，防止字符串空格或类型不同
    feature_asins = set(
        feature_df["asin"]
        .astype(str)
        .str.strip()
        .dropna()
        .unique()
    )

    scot_asins = set(
        scot_df["asin"]
        .astype(str)
        .str.strip()
        .dropna()
        .unique()
    )

    inner_asins = feature_asins & scot_asins

    result = {
        "cut_date": cut_date.date(),
        "feature_unique_asins": len(feature_asins),
        "scot_unique_asins": len(scot_asins),
        "inner_unique_asins": len(inner_asins),
        "feature_coverage": (
            len(inner_asins) / len(feature_asins)
            if feature_asins else 0
        ),
    }

    results.append(result)

    print(
        f"{cut_date.date()} | "
        f"Feature={len(feature_asins):,} | "
        f"SCOT={len(scot_asins):,} | "
        f"Inner={len(inner_asins):,} | "
        f"Coverage={result['feature_coverage']:.2%}"
    )

    del feature_df, scot_df, feature_asins, scot_asins, inner_asins


# 4. 汇总结果
results_df = pd.DataFrame(results)

print("\n" + "=" * 80)
print(results_df.to_string(index=False))
